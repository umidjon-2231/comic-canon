{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comic-canon/schema/character.schema.json",
  "title": "Character",
  "description": "Validates the YAML frontmatter of a character file in /canon/characters.",
  "type": "object",
  "required": ["id", "type", "status", "role", "first_appears", "alive"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^CHR-[0-9]{3}$" },
    "type": { "const": "character" },
    "status": { "enum": ["canon", "draft", "deprecated"] },
    "version": { "type": "integer", "minimum": 1 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "role": { "enum": ["protagonist", "antagonist", "ally", "mentor", "rival", "foil", "minor"] },
    "first_appears": { "type": "string", "pattern": "^S[0-9]{2}-[0-9]{3}$" },
    "alive": { "type": "boolean" },
    "status_intervals": {
      "type": "array",
      "description": "Time-bounded facts (FACTTRACK-style). valid_until null = still true.",
      "items": {
        "type": "object",
        "required": ["fact", "valid_from"],
        "properties": {
          "fact": { "type": "string" },
          "valid_from": { "type": "string", "pattern": "^S[0-9]{2}-[0-9]{3}$" },
          "valid_until": {
            "anyOf": [
              { "type": "null" },
              { "type": "string", "pattern": "^S[0-9]{2}-[0-9]{3}$" }
            ]
          }
        }
      }
    }
  }
}
